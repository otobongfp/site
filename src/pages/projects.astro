---
import { getCollection } from 'astro:content';

import BaseLayout from '../layouts/BaseLayout.astro';

import ContactCTA from '../components/ContactCTA.astro';
import PortfolioPreview from '../components/PortfolioPreview.astro';
import Hero from '../components/Hero.astro';
import Grid from '../components/Grid.astro';

const projects = (await getCollection('work')).sort(
	(a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);
---

<BaseLayout
	title="My Work | Otobong Peter"
	description="Learn about Otobong Peter's most recent projects"
>
	<div class="stack gap-20">
		<main class="wrapper stack gap-8">
			<Hero
				title="Projects & Writings"
				tagline="See my most recent projects below to get an idea of my past experience."
				align="start"
			/>
			<div>
				<h4>Projects</h4>
				<p>CLI Note taking app written in Rust <a target="_blank" href="https://github.com/otobongfp/Notes_App">here</a></p>
				<p>LTO Blockchain's Private layer communication service <a target="_blank"  href="https://github.com/otobongfp/relay-service">here</a>[contribution]</p>
				<p>Hangman game, written in haskell<a target="_blank"  href="https://github.com/otobongfp/hangman-game">here</a></p>
			</div>
			<div>
				<h4>Articles & Papers</h4>
				<p>Kings Landing <a href="lol">here</a></p>
			</div>
			<!-- <Grid variant="offset">
				{
					projects.map((project) => (
						<li>
							<PortfolioPreview project={project} />
						</li>
					))
				}
			</Grid> -->
		</main>
		<ContactCTA />
	</div>
</BaseLayout>